Include src/service/get
Include src/service/control
Include src/openlist/app
Include src/openlist/acc
Include src/openlist/api
Include src/openlist/act

echo
openlist_options=( '文件管理' 'OpenList管理' '账号管理' '退出' )
inquirer list_input_index "请选择" openlist_options openlist_options_index

case $openlist_options_index in
    0) 
        OpenListAct
    ;;
    1) 
        echo
        openlist_app_options=( '查看' '添加' '修改' '删除' '本地安装/升级' )
        inquirer list_input_index "选择操作" openlist_app_options openlist_app_options_index

        case $openlist_app_options_index in
            0) OpenListAppView
            ;;
            1) OpenListAppAdd
            ;;
            2) OpenListAppEdit
            ;;
            3) OpenListAppDel
            ;;
            4) OpenListAppInstall
            ;;
        esac
    ;;
    2) 
        echo
        openlist_acc_options=( '查看' '添加' '登陆' '修改' '删除' )
        inquirer list_input_index "选择操作" openlist_acc_options openlist_acc_options_index

        case $openlist_acc_options_index in
            0) OpenListAccView
            ;;
            1) OpenListAccAdd
            ;;
            2) OpenListAccLogin
            ;;
            3) OpenListAccEdit
            ;;
            4) OpenListAccDel
            ;;
        esac
    ;;
    *) 
    ;;
esac

exit 0
