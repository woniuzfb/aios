    return 1
}

V2raySetUserId()
{
    Println "$tip 必须为合法的 UUID"
    inquirer text_input "输入用户 ID: " user_id "$i18n_random"

    if [ "$user_id" == "$i18n_random" ] 
    then
        user_id=$($V2CTL_FILE uuid)
        Println "  id: ${green} $user_id ${normal}"
    fi
}

V2raySetUserLevel()
{
