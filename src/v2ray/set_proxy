V2raySetUserLevelValidator()
{
    if [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -gt 0 ] && [ "$1" -le $((policy_levels_count+1)) ]
    then
        return 0
    fi

    return 1
}

V2raySetUserAlterIdValidator()
{
    if [[ "$1" =~ ^[0-9]+$ ]] && [ "$1" -ge 0 ] && [ "$1" -le 65535 ]
