V2raySetVliteuHandshakeMaskingPaddingSizeValidator()
{
    if [ "$1" == "0" ] || [[ "$1" =~ ^[1-9][0-9]*$ ]]
    then
        return 0
    fi

    return 1
}

V2raySetHttpPortValidator()
{
    if [[ "$1" =~ ^[1-9][0-9]*$ ]] && [ "$1" -le 65535 ]
    then
